# Wails build output
build/bin/

# Wails-generated JS/TS bindings (regenerated by `wails dev`/`wails build`).
# The frontend calls window.go.main.App directly, so these are not committed.
frontend/wailsjs/

# Node (should stay empty — the frontend is static, no bundler)
frontend/node_modules/

# Preview-only variant generated for screenshots
frontend/dist/index-light.html
